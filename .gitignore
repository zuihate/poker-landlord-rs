# Generated by Cargo
# 编译产物和可执行文件
/target/
debug/
release/

# 临时文件和日志
*.log
*.tmp

# IDE 和编辑器产生的文件
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Rust 特有的缓存和构建文件
**/*.rs.bk
Cargo.lock.bak

# 如果你使用 cargo-expand 或其他工具产生的文件
expand/

# 测试覆盖率报告（可选）
lcov.info
coverage/

# 文档生成目录（如果以后用 mdBook 或 cargo doc）
docs/
book/
.env
